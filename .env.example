# Brand Sniper Monorepo - Global Environment Template
# Copy this file to '.env' in the root directory.
#
# Shared configuration lives here. App-specific secrets go in
# apps/<service>/.env. Each app loads root .env first, then its own.

# ==========================================
# 1. Database (shared by all services)
# ==========================================
# Local dev (Docker): uncomment postgres in docker-compose.yml
#   DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/brand_sniper"
# Cloud (Azure):
DATABASE_URL="postgresql+asyncpg://postgres:your-password@brand-sniper-db.postgres.database.azure.com:5432/brand_sniper"

# ==========================================
# 2. AI Verification & Agentic CFO
# ==========================================
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ==========================================
# 3. Observability & UI
# ==========================================
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="admin"
