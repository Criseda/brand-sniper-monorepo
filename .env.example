# Brand Sniper Monorepo - Global Environment Template
# Copy this file to '.env' in the root directory.
#
# Shared configuration lives here. App-specific secrets go in
# apps/<service>/.env. Each app loads root .env first, then its own.

# ==========================================
# 1. Database (shared by all services)
# ==========================================
# Local dev (Docker): uncomment postgres in docker-compose.yml
#   DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/brand_sniper"
# Cloud (Azure):
DATABASE_URL="postgresql+asyncpg://postgres:changeme@changeme-host.postgres.database.azure.com:5432/brand_sniper"

# ==========================================
# 2. AI Verification & Agentic CFO
# ==========================================
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"

# ==========================================
# 3. Edge Node / Marketplace Credentials
# ==========================================
# Skinport API credentials for the listener
SKINPORT_CLIENT_ID="your_skinport_client_id"
SKINPORT_CLIENT_SECRET="your_skinport_client_secret"

# Listener platform target (default: "skinport")
LISTENER_PLATFORM="skinport"

# ==========================================
# 4. Compute Node (Backend) Configuration
# ==========================================
# How the listener / analytics reach the backend
COMPUTE_NODE_IP="localhost"
COMPUTE_NODE_PORT="8080"
COMPUTE_NODE_URL="http://localhost:8080"

# CORS origins configuration (comma-separated origins allowed to make credentialed requests)
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# ==========================================
# 5. Edge Redis Cache
# ==========================================
# Redis for sliding-window Z-score cache and baselines (port 6380)
EDGE_REDIS_URL="redis://localhost:6380"

# ==========================================
# 6. MLflow Tracking
# ==========================================
MLFLOW_TRACKING_URI="http://localhost:5000"

# ==========================================
# 7. Anomaly Detection Parameters
# ==========================================
# Minimum absolute savings required for non-stickered anomaly validation
MIN_SAVINGS_USD="0.50"
# Z-score threshold for standard items
Z_SCORE_THRESHOLD="-2.0"
# Z-score threshold for stickered items (relaxed)
Z_SCORE_STICKER_THRESHOLD="-1.0"
# Minimum std dev regularization factor
MIN_STD_DEV_FACTOR="0.04"
# Sliding window size for Redis price history
SLIDING_WINDOW_SIZE="20"
# Minimum data points required before Z-score analysis
MIN_HISTORY_POINTS="4"
# Batch buffer chunk limit for bulk ingest dispatches
CHUNK_LIMIT="2500"
# Dedup cache max entries (LRU eviction above this cap)
DEDUP_CACHE_MAX_SIZE="25000"
# Enable macro Z-score fallback for illiquid items (uses long-term volatility from Redis baseline)
MACRO_ZSCORE_FALLBACK="true"
# Prior weight for Bayesian shrinkage of local stddev toward macro volatility
MACRO_PRIOR_WEIGHT="5.0"

# ==========================================
# 8. Observability & UI
# ==========================================
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="admin"
