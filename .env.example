# Brand Sniper Monorepo - Global Environment Template
# Copy this file to '.env' in the root directory.

# ==========================================
# 1. AI Verification & Agentic CFO
# ==========================================
# Used by the offline Prefect Pipeline in apps/analytics to audit trades.
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ==========================================
# 2. Database & Orchestration (Docker defaults)
# ==========================================
# These match the default credentials inside the docker-compose stacks.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="brand_sniper"
DATABASE_URL="postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}"

# ==========================================
# 3. Observability & UI
# ==========================================
# Default login for Grafana (http://localhost:3000) is admin/admin
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="admin"
