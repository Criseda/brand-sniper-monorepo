# Listener Microservice - App-specific overrides
# Shared vars (DATABASE_URL, etc.) come from root .env
# Copy this file to '.env'

# 1. Skinport API Credentials
SKINPORT_CLIENT_ID="your_client_id_here"
SKINPORT_CLIENT_SECRET="your_client_secret_here"

# 2. Network Targets
COMPUTE_NODE_IP="localhost"

# 3. Cloudflare Bypass (required for Skinport WebSocket)
# Run: node scrapers/skinport_websocket/sidecar.js to generate
CLOUDFLARE_COOKIE="your_cf_clearance_cookie_here"

# 4. Redis Hot Cache (Edge Node local Redis, port 6380 if via Pi5 docker-compose)
REDIS_URL="redis://localhost:6379"