# Trading Platform API Credentials
SKINPORT_CLIENT_ID="your_skinport_client_id_here"
SKINPORT_CLIENT_SECRET="your_skinport_client_secret_here"

# Network Targets (Optional - Defaults to localhost if omitted)
COMPUTE_NODE_IP=localhost

# Cloudflare Ingestion Bypasses (Required for Live WebSockets)
CLOUDFLARE_COOKIE="your_cf_clearance_cookie_here"

# Telemetry Debugging (Disable or enable to watch logs/prevent log noise)
DEBUG_TELEMETRY="false"

# --- Tunable Anomaly Detection Parameters ---
# Minimum absolute savings in USD required for standard (non-stickered) items
MIN_SAVINGS_USD="0.75"

# Z-score outlier trigger thresholds
Z_SCORE_THRESHOLD="-2.5"
Z_SCORE_STICKER_THRESHOLD="-1.0"

# Floor factor for standard deviation (4% of mean) to avoid hyper-sensitivity
MIN_STD_DEV_FACTOR="0.04"

# Sliding window size of prices cached in Redis
SLIDING_WINDOW_SIZE="30"

# Minimum prices needed in historical window to calculate Z-score
MIN_HISTORY_POINTS="4"

# Memory caps and batch buffering controls
DEDUP_CACHE_MAX_SIZE="25000"
CHUNK_LIMIT="2500"