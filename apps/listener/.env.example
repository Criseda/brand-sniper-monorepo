# Listener Microservice Environment Config
# Copy this file to '.env'

# 1. Scraping Core
MARKETPLACE_WEBSOCKET_URL="wss://example-marketplace.com/socket"
POLLING_INTERVAL_SECONDS=5

# 2. Redis Hot Cache (Fast Path)
REDIS_URL="redis://localhost:6379"

# 3. Postgres Cold Storage (Slow Path)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/brand_sniper"