# Server Runtime
PORT=8080
HOST=0.0.0.0

# Langfuse
LANGFUSE_PUBLIC_KEY=your_copied_public_key
LANGFUSE_SECRET_KEY=your_copied_secret_key
LANGFUSE_HOST=your_langfuse_host

# Database Core Topology
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/brand_sniper

# Google Gen AI Gateway
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# OpenTelemetry Observability
OTEL_SERVICE_NAME=brand-sniper-backend