# Backend Microservice Environment Config
# Copy this file to '.env'

# 1. Observability
OTEL_SERVICE_NAME="brand-sniper-backend"

# 2. Cache Layer (DRE O(1) Lookup)
REDIS_URL="redis://localhost:6379"

# 3. Database Layer (Paper Executor)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/brand_sniper"