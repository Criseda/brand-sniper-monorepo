{
  "title": "Brand Sniper Live Dashboard",
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "Total Simulated PnL (USD)",
      "targets": [
        {
          "expr": "paper_trading_estimated_profit_total / 100",
          "legendFormat": "USD",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "unit": "currencyUSD"
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Trades Executed",
      "targets": [
        {
          "expr": "paper_trades_executed_total",
          "legendFormat": "Trades",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "none",
        "graphMode": "area"
      }
    },
    {
      "type": "timeseries",
      "title": "DRE Latency (ms)",
      "targets": [
        {
          "expr": "rate(rules_engine_latency_seconds_sum[1m]) / rate(rules_engine_latency_seconds_count[1m]) * 1000",
          "legendFormat": "Avg Latency (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    }
  ],
  "schemaVersion": 38,
  "refresh": "5s"
}
